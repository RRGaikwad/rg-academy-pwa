rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }
    function role() {
      return request.auth.token.role;
    }
    function institute() {
      return request.auth.token.instituteId;
    }
    function isAdmin(instituteId) {
      return isAuth() && role() == 'admin' && institute() == instituteId;
    }
    function isTeacher(instituteId) {
      return isAuth() && role() == 'teacher' && institute() == instituteId;
    }
    function isStudent(instituteId) {
      return isAuth() && role() == 'student' && institute() == instituteId;
    }
    function ownsTeacherDoc(teacherId) {
      return isTeacher(institute()) && request.auth.uid == teacherId;
    }
    function ownsStudentDoc(studentId) {
      return isStudent(institute()) && request.auth.uid == studentId;
    }
    function teacherOwnsBatch(instituteId, batchId) {
      return isTeacher(instituteId) &&
        batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/teachers/$(request.auth.uid)).data.batchIds;
    }
    function studentEnrolledInBatch(instituteId, batchId) {
      return isStudent(instituteId) &&
        batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/students/$(request.auth.uid)).data.batchIds;
    }

    match /institutes/{instituteId} {
      allow read: if isAuth() && institute() == instituteId;
      allow write: if isAdmin(instituteId);
      
      match /students/{studentId} {
        allow read: if isAdmin(instituteId) || ownsStudentDoc(studentId);
        allow write: if isAdmin(instituteId);
      }
      
      match /teachers/{teacherId} {
        allow read: if isAdmin(instituteId) || ownsTeacherDoc(teacherId);
        allow write: if isAdmin(instituteId);
      }
      
      match /batches/{batchId} {
        allow read: if isAdmin(instituteId) || teacherOwnsBatch(instituteId, batchId) || studentEnrolledInBatch(instituteId, batchId);
        allow write: if isAdmin(instituteId);
      }
      
      match /fees/{feeId} {
        allow read: if isAdmin(instituteId) || (isStudent(instituteId) && resource.data.studentId == request.auth.uid);
        allow write: if isAdmin(instituteId);
      }
      
      match /exams/{examId} {
        allow read: if isAdmin(instituteId) || 
          (isTeacher(instituteId) && resource.data.batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/teachers/$(request.auth.uid)).data.batchIds) || 
          (isStudent(instituteId) && resource.data.batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/students/$(request.auth.uid)).data.batchIds);
        allow create, update, delete: if isTeacher(instituteId) && request.resource.data.batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/teachers/$(request.auth.uid)).data.batchIds;
      }
      
      match /submissions/{submissionId} {
        allow read: if isAdmin(instituteId) || 
          (isTeacher(instituteId) && resource.data.batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/teachers/$(request.auth.uid)).data.batchIds) || 
          (isStudent(instituteId) && resource.data.studentId == request.auth.uid);
        allow create: if isStudent(instituteId) && request.resource.data.studentId == request.auth.uid;
        allow update: if isStudent(instituteId) && resource.data.studentId == request.auth.uid && request.resource.data.studentId == request.auth.uid;
      }
      
      match /materials/{materialId} {
        allow read: if isAdmin(instituteId) || 
          (isTeacher(instituteId) && resource.data.batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/teachers/$(request.auth.uid)).data.batchIds) || 
          (isStudent(instituteId) && (resource.data.scope == 'institute' || resource.data.batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/students/$(request.auth.uid)).data.batchIds));
        allow write: if isAdmin(instituteId) || 
          (isTeacher(instituteId) && request.resource.data.batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/teachers/$(request.auth.uid)).data.batchIds);
      }
      
      match /announcements/{annoId} {
        allow read: if isAdmin(instituteId) || isTeacher(instituteId) || 
          (isStudent(instituteId) && (resource.data.scope == 'institute' || resource.data.batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/students/$(request.auth.uid)).data.batchIds));
        allow write: if isAdmin(instituteId) || 
          (isTeacher(instituteId) && request.resource.data.batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/teachers/$(request.auth.uid)).data.batchIds);
      }
      
      match /leaderboard/{batchId} {
        allow read: if isAdmin(instituteId) || 
          (isTeacher(instituteId) && batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/teachers/$(request.auth.uid)).data.batchIds) || 
          (isStudent(instituteId) && batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/students/$(request.auth.uid)).data.batchIds) || 
          batchId == 'institute';
        allow write: if false; // written by functions only
      }
      
      match /attendance/{batchId}/records/{date} {
        allow read: if isAdmin(instituteId) || 
          (isTeacher(instituteId) && batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/teachers/$(request.auth.uid)).data.batchIds);
        allow write: if isTeacher(instituteId) && batchId in get(/databases/$(database)/documents/institutes/$(instituteId)/teachers/$(request.auth.uid)).data.batchIds;
      }
    }
  }
}
