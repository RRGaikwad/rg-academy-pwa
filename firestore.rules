rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    // The source of truth for all roles is now the users collection keyed by email
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role;
    }
    
    function isAdmin() {
      return isAuth() && getUserRole() == 'admin';
    }
    
    function isTeacher() {
      return isAuth() && getUserRole() == 'teacher';
    }
    
    function isStudent() {
      return isAuth() && getUserRole() == 'student';
    }
    
    function teacherOwnsBatch(batchId) {
      return isTeacher() && batchId in get(/databases/$(database)/documents/teachers/$(request.auth.token.email)).data.batchIds;
    }
    
    function studentEnrolledInBatch(batchId) {
      return isStudent() && batchId in get(/databases/$(database)/documents/students/$(request.auth.token.email)).data.batchIds;
    }

    match /users/{emailId} {
      allow read: if isAuth() && (request.auth.token.email == emailId || isAdmin());
      allow write: if isAdmin();
    }

    match /teachers/{emailId} {
      allow read: if isAuth(); 
      allow write: if isAdmin();
    }

    match /students/{emailId} {
      allow read: if isAuth(); 
      allow write: if isAdmin();
    }

    match /batches/{batchId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /fees/{feeId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isTeacher();
    }

    match /submissions/{subId} {
      allow read: if isAuth();
      allow create: if isAuth() && isStudent();
      allow update, delete: if isAuth() && (isAdmin() || isTeacher());
    }

    match /materials/{matId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isTeacher();
    }

    match /announcements/{annId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isTeacher();
    }

    match /leaderboard/{batchId} {
      allow read: if isAuth();
      allow write: if isAuth(); 
    }

    match /attendance/{recordId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isTeacher();
    }
  }
}
