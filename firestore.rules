rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null && request.auth.token.email != null;
    }

    // Safe role lookup — uses exists() first so we never call .data on a null document.
    // If the users/{email} document doesn't exist yet, the role defaults to 'none'.
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.token.email))
        ? get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role
        : 'none';
    }

    function isAdmin() {
      return isAuth() && getUserRole() == 'admin';
    }

    function isTeacher() {
      return isAuth() && getUserRole() == 'teacher';
    }

    function isStudent() {
      return isAuth() && getUserRole() == 'student';
    }

    // ─── users ───────────────────────────────────────────────────────────────
    // Any authenticated user may read profile documents. This avoids strict
    // email matching errors if there's a trailing space in the document ID.
    // Admins may write to ANY profile document.
    match /users/{emailId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── teachers ────────────────────────────────────────────────────────────
    match /teachers/{emailId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── students ────────────────────────────────────────────────────────────
    match /students/{emailId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── batches ─────────────────────────────────────────────────────────────
    match /batches/{batchId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── fees ────────────────────────────────────────────────────────────────
    match /fees/{feeId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── exams ───────────────────────────────────────────────────────────────
    match /exams/{examId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isTeacher();
    }

    // ─── submissions ─────────────────────────────────────────────────────────
    match /submissions/{subId} {
      allow read: if isAuth();
      allow create: if isStudent();
      allow update, delete: if isAdmin() || isTeacher();
    }

    // ─── materials ───────────────────────────────────────────────────────────
    match /materials/{matId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isTeacher();
    }

    // ─── announcements ───────────────────────────────────────────────────────
    match /announcements/{annId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isTeacher();
    }

    // ─── leaderboard ─────────────────────────────────────────────────────────
    match /leaderboard/{batchId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isTeacher();
    }

    // ─── attendance ──────────────────────────────────────────────────────────
    match /attendance/{recordId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isTeacher();
    }
  }
}
